{
  "name": "traceshadow",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "workspaces": [
    "apps/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "python3 -m uvicorn apps.backend.app.main:app --reload --host 0.0.0.0 --port 4000",
    "dev:frontend": "npm --workspace apps/frontend run dev -- --host localhost --port 5173 --strictPort",
    "build": "npm run build -w apps/frontend",
    "check": "npm run check:backend && npm run build -w apps/frontend",
    "check:backend": "python3 -m py_compile apps/backend/app/main.py",
    "install:backend": "python3 -m pip install -r apps/backend/requirements.txt",
    "install:browsers": "python3 -m playwright install chromium"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.4"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
